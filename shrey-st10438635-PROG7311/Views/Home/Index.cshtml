@{
    ViewData["Title"] = "Dashboard";
}

<style>
    .stat-card {
        transition: all 0.2s ease;
        border: 1px solid rgba(10, 22, 40, 0.07) !important;
    }

        .stat-card:hover {
            border-color: rgba(10, 22, 40, 0.3) !important;
            box-shadow: 0 0 18px rgba(10, 22, 40, 0.15), 0 4px 12px rgba(10, 22, 40, 0.1) !important;
            transform: translateY(-2px);
        }
</style>

<div class="row mb-4">
    <div class="col">
        <h2 class="fw-bolder fs-1">Dashboard</h2>
        <p class="text-muted">Welcome to the Global Logistics Management System — TechMove Logistics</p>
    </div>
</div>

<div class="row g-4 mb-5">
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                    <i class="bi bi-people-fill fs-3 text-primary"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@ViewBag.TotalClients</div>
                    <div class="text-muted small">Total Clients</div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pb-3">
                <a asp-controller="Clients" asp-action="Index" class="btn btn-sm btn-outline-primary w-100">View Clients</a>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-success bg-opacity-10 p-3">
                    <i class="bi bi-file-earmark-check-fill fs-3 text-success"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@ViewBag.TotalContracts</div>
                    <div class="text-muted small">Total Contracts</div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pb-3">
                <a asp-controller="Contracts" asp-action="Index" class="btn btn-sm btn-outline-success w-100">View Contracts</a>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-warning bg-opacity-10 p-3">
                    <i class="bi bi-check-circle-fill fs-3 text-warning"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@ViewBag.ActiveContracts</div>
                    <div class="text-muted small">Active Contracts</div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pb-3">
                <a asp-controller="Contracts" asp-action="Index" asp-route-status="Active" class="btn btn-sm btn-outline-warning w-100">View Active</a>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-info bg-opacity-10 p-3">
                    <i class="bi bi-clipboard2-data-fill fs-3 text-info"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@ViewBag.TotalRequests</div>
                    <div class="text-muted small">Service Requests</div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pb-3">
                <a asp-controller="ServiceRequests" asp-action="Index" class="btn btn-sm btn-outline-info w-100">View Requests</a>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-lightning-charge"></i> Quick Actions
            </div>
            <div class="list-group list-group-flush">
                <a asp-controller="Clients" asp-action="Create" class="list-group-item list-group-item-action">
                    <i class="bi bi-person-plus text-primary me-2"></i> Add New Client
                </a>
                <a asp-controller="Contracts" asp-action="Create" class="list-group-item list-group-item-action">
                    <i class="bi bi-file-earmark-plus text-success me-2"></i> Create Contract
                </a>
                <a asp-controller="ServiceRequests" asp-action="Create" class="list-group-item list-group-item-action">
                    <i class="bi bi-plus-circle text-info me-2"></i> Raise Service Request
                </a>
            </div>
        </div>
    </div>
</div>
@model shrey_st10438635_PROG7311.Models.Client
@{
    ViewData["Title"] = "Edit Client";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-warning text-dark">
                <i class="bi bi-pencil"></i> Edit Client — @Model.Name
            </div>
            <div class="card-body">
                <form asp-action="Edit">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ContactEmail" class="form-label fw-semibold"></label>
                        <input asp-for="ContactEmail" class="form-control" />
                        <span asp-validation-for="ContactEmail" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ContactPhone" class="form-label fw-semibold"></label>
                        <input asp-for="ContactPhone" class="form-control" />
                        <span asp-validation-for="ContactPhone" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Region" class="form-label fw-semibold"></label>
                        <select asp-for="Region" class="form-select">
                            <option>Africa</option>
                            <option>Europe</option>
                            <option>North America</option>
                            <option>South America</option>
                            <option>Asia Pacific</option>
                            <option>Middle East</option>
                        </select>
                        <span asp-validation-for="Region" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning"><i class="bi bi-save"></i> Update</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}

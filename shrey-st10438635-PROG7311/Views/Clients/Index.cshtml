@model IEnumerable<shrey_st10438635_PROG7311.Models.Client>
@{
    ViewData["Title"] = "Clients";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-people text-primary"></i> Clients</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-person-plus"></i> Add Client
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Region</th>
                    <th class="text-center">Contracts</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var client in Model)
                {
                    <tr>
                        <td class="fw-semibold">@client.Name</td>
                        <td>@client.ContactEmail</td>
                        <td>@client.ContactPhone</td>
                        <td><span class="badge bg-secondary">@client.Region</span></td>
                        <td class="text-center">
                            <span class="badge bg-primary">@client.Contracts.Count</span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@client.Id" class="btn btn-sm btn-outline-info">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@client.Id" class="btn btn-sm btn-outline-warning">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@client.Id" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">No clients found. <a asp-action="Create">Add one now.</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

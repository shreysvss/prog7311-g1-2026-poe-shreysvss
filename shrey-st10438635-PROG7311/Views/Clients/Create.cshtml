@model shrey_st10438635_PROG7311.Models.Client
@{
    ViewData["Title"] = "Add Client";
}

@*
    Shrey Singh
    ST10438635
    References:
    <Perumal, N., 2026. PROG7311 POE Part Two Workshop. [lecture] The Independent Institute of Education, 15 April 2026.>
    <Microsoft, 2026. Razor syntax reference for ASP.NET Core. [online] Microsoft Learn. Available at: https://learn.microsoft.com/en-us/aspnet/core/mvc/views/razor [Accessed 15 April 2026].>
    <W3Schools, 2026. Bootstrap 5 Tutorial. [online] W3Schools. Available at: https://www.w3schools.com/bootstrap5 [Accessed 16 April 2026].>
    <Tutorials Teacher, 2026. Tag Helpers in ASP.NET Core. [online] Available at: https://www.tutorialsteacher.com/core/aspnet-core-tag-helpers [Accessed 17 April 2026].>
    <MDN Web Docs, 2026. JavaScript Fetch API. [online] Mozilla Developer Network. Available at: https://developer.mozilla.org/en-US/docs/Web/API/Fetch_API [Accessed 18 April 2026].>
*@

<div class="row justify-content-center">  
    <div class="col-md-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-person-plus"></i> Add New Client
            </div>
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold"></label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. Global Freight Co" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ContactEmail" class="form-label fw-semibold"></label>
                        <input asp-for="ContactEmail" class="form-control" placeholder="contact@company.com" />
                        <span asp-validation-for="ContactEmail" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ContactPhone" class="form-label fw-semibold"></label>
                        <input asp-for="ContactPhone" class="form-control" placeholder="+27112345678" />
                        <span asp-validation-for="ContactPhone" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Region" class="form-label fw-semibold"></label>
                        <select asp-for="Region" class="form-select">
                            <option value="">-- Select Region --</option>
                            <option>Africa</option>
                            <option>Europe</option>
                            <option>North America</option>
                            <option>South America</option>
                            <option>Asia Pacific</option>
                            <option>Middle East</option>
                        </select>
                        <span asp-validation-for="Region" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Save Client</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}

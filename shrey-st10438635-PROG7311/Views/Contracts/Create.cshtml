@model shrey_st10438635_PROG7311.Models.Contract
@{
    ViewData["Title"] = "New Contract";
}
<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-success text-white">
                <i class="bi bi-file-earmark-plus"></i> Create New Contract
            </div>
            <div class="card-body">
                <form asp-action="Create" enctype="multipart/form-data" id="contractForm">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="ClientId" class="form-label fw-semibold">Client</label>
                            <select asp-for="ClientId" asp-items="ViewBag.Clients" class="form-select">
                                <option value="">-- Select Client --</option>
                            </select>
                            <span asp-validation-for="ClientId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Title" class="form-label fw-semibold"></label>
                            <input asp-for="Title" class="form-control" placeholder="e.g. SA Distribution Contract" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="StartDate" class="form-label fw-semibold"></label>
                            <input asp-for="StartDate" class="form-control" type="date" />
                            <span asp-validation-for="StartDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="EndDate" class="form-label fw-semibold"></label>
                            <input asp-for="EndDate" class="form-control" type="date" />
                            <span asp-validation-for="EndDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Status" class="form-label fw-semibold"></label>
                            <select asp-for="Status" asp-items="Html.GetEnumSelectList<ContractStatus>()" class="form-select"></select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ServiceLevel" class="form-label fw-semibold"></label>
                            <select asp-for="ServiceLevel" asp-items="Html.GetEnumSelectList<ServiceLevel>()" class="form-select"></select>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label fw-semibold">Signed Agreement <span class="text-muted">(PDF only)</span></label>
                            <input type="file" name="signedAgreement" id="signedAgreement" class="form-control" accept=".pdf" />
                            <div class="form-text">
                                <i class="bi bi-info-circle"></i>
                                Maximum file size: <strong>5 MB</strong>. Only PDF files are allowed.
                            </div>
                            <div id="fileSizeError" class="text-danger small mt-1" style="display:none;"></div>
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-success" id="submitBtn"><i class="bi bi-save"></i> Create Contract</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        const MAX_FILE_SIZE_MB = 5;
        const MAX_FILE_SIZE_BYTES = MAX_FILE_SIZE_MB * 1024 * 1024;

        const fileInput = document.getElementById('signedAgreement');
        const errorBox = document.getElementById('fileSizeError');
        const submitBtn = document.getElementById('submitBtn');

        fileInput.addEventListener('change', function () {
            errorBox.style.display = 'none';
            errorBox.textContent = '';
            submitBtn.disabled = false;

            if (this.files.length === 0) return;

            const file = this.files[0];
            const fileSizeMB = (file.size / (1024 * 1024)).toFixed(2);

            if (file.size > MAX_FILE_SIZE_BYTES) {
                errorBox.textContent = `File is ${fileSizeMB} MB — maximum allowed is ${MAX_FILE_SIZE_MB} MB. Please choose a smaller file.`;
                errorBox.style.display = 'block';
                submitBtn.disabled = true;
                this.value = '';
            }
        });
    </script>
}
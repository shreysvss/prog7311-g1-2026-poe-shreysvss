@model shrey_st10438635_PROG7311.Models.Contract
@{
    ViewData["Title"] = "New Contract";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-success text-white">
                <i class="bi bi-file-earmark-plus"></i> Create New Contract
            </div>
            <div class="card-body">
                <form asp-action="Create" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="ClientId" class="form-label fw-semibold">Client</label>
                            <select asp-for="ClientId" asp-items="ViewBag.Clients" class="form-select">
                                <option value="">-- Select Client --</option>
                            </select>
                            <span asp-validation-for="ClientId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Title" class="form-label fw-semibold"></label>
                            <input asp-for="Title" class="form-control" placeholder="e.g. SA Distribution Contract" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="StartDate" class="form-label fw-semibold"></label>
                            <input asp-for="StartDate" class="form-control" type="date" />
                            <span asp-validation-for="StartDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="EndDate" class="form-label fw-semibold"></label>
                            <input asp-for="EndDate" class="form-control" type="date" />
                            <span asp-validation-for="EndDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Status" class="form-label fw-semibold"></label>
                            <select asp-for="Status" asp-items="Html.GetEnumSelectList<ContractStatus>()" class="form-select"></select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ServiceLevel" class="form-label fw-semibold"></label>
                            <select asp-for="ServiceLevel" asp-items="Html.GetEnumSelectList<ServiceLevel>()" class="form-select"></select>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label fw-semibold">Signed Agreement <span class="text-muted">(PDF only)</span></label>
                            <input type="file" name="signedAgreement" class="form-control" accept=".pdf" />
                            <div class="form-text">Upload the signed contract PDF document.</div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-success"><i class="bi bi-save"></i> Create Contract</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}

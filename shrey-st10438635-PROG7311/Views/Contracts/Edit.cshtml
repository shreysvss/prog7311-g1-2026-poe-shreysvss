@model shrey_st10438635_PROG7311.Models.Contract
@{
    ViewData["Title"] = "Edit Contract";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-warning text-dark">
                <i class="bi bi-pencil"></i> Edit Contract — @Model.Title
            </div>
            <div class="card-body">
                <form asp-action="Edit" enctype="multipart/form-data" id="contractForm">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="SignedAgreementPath" />
                    <input type="hidden" asp-for="SignedAgreementFileName" />
                    <input type="hidden" asp-for="CreatedAt" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="ClientId" class="form-label fw-semibold">Client</label>
                            <select asp-for="ClientId" asp-items="ViewBag.Clients" class="form-select"></select>
                            <span asp-validation-for="ClientId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Title" class="form-label fw-semibold"></label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="StartDate" class="form-label fw-semibold"></label>
                            <input asp-for="StartDate" class="form-control" type="date" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="EndDate" class="form-label fw-semibold"></label>
                            <input asp-for="EndDate" class="form-control" type="date" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Status" class="form-label fw-semibold"></label>
                            <select asp-for="Status" asp-items="Html.GetEnumSelectList<ContractStatus>()" class="form-select"></select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ServiceLevel" class="form-label fw-semibold"></label>
                            <select asp-for="ServiceLevel" asp-items="Html.GetEnumSelectList<ServiceLevel>()" class="form-select"></select>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label fw-semibold">Replace Signed Agreement <span class="text-muted">(PDF only)</span></label>
                            @if (!string.IsNullOrEmpty(Model.SignedAgreementFileName))
                            {
                                <div class="alert alert-info py-2 mb-2 small">
                                    <i class="bi bi-file-earmark-pdf text-danger"></i>
                                    Current file: <strong>@Model.SignedAgreementFileName</strong>
                                    <a asp-action="Download" asp-route-id="@Model.Id" class="ms-2">(Download)</a>
                                </div>
                            }
                            <input type="file" name="signedAgreement" id="signedAgreement" class="form-control" accept=".pdf" />
                            <div class="form-text">
                                <i class="bi bi-info-circle"></i>
                                Maximum file size: <strong>5 MB</strong>. Only PDF files are allowed. Leave blank to keep current file.
                            </div>
                            <div id="fileSizeError" class="text-danger small mt-1" style="display:none;"></div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-warning" id="submitBtn"><i class="bi bi-save"></i> Update Contract</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        const MAX_FILE_SIZE_MB = 5;
        const MAX_FILE_SIZE_BYTES = MAX_FILE_SIZE_MB * 1024 * 1024;

        const fileInput = document.getElementById('signedAgreement');
        const errorBox = document.getElementById('fileSizeError');
        const submitBtn = document.getElementById('submitBtn');

        fileInput.addEventListener('change', function () {
            errorBox.style.display = 'none';
            errorBox.textContent = '';
            submitBtn.disabled = false;

            if (this.files.length === 0) return;

            const file = this.files[0];
            const fileSizeMB = (file.size / (1024 * 1024)).toFixed(2);

            if (file.size > MAX_FILE_SIZE_BYTES) {
                errorBox.textContent = `File is ${fileSizeMB} MB — maximum allowed is ${MAX_FILE_SIZE_MB} MB. Please choose a smaller file.`;
                errorBox.style.display = 'block';
                submitBtn.disabled = true;
                this.value = '';
            }
        });
    </script>
}
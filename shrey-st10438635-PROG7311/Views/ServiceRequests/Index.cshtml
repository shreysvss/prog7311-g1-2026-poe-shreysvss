@model IEnumerable<shrey_st10438635_PROG7311.Models.ServiceRequest>
@{
    ViewData["Title"] = "Service Requests";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-clipboard-check text-info"></i> Service Requests</h2>
    <a asp-action="Create" class="btn btn-info text-white">
        <i class="bi bi-plus-circle"></i> New Request
    </a>
</div>
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Contract</th>
                    <th>Client</th>
                    <th>Description</th>
                    <th>Cost (USD)</th>
                    <th>Cost (ZAR)</th>
                    <th>Rate</th>
                    <th>Status</th>
                    <th>Date</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var sr in Model)
                {
                    <tr>
                        <td class="text-muted small">@sr.Id</td>
                        <td class="fw-semibold">@sr.Contract?.Title</td>
                        <td>@sr.Contract?.Client?.Name</td>
                        <td>@(sr.Description.Length > 40 ? sr.Description[..40] + "…" : sr.Description)</td>
                        <td class="text-success fw-semibold">@($"${sr.CostUSD.ToString("N2")}")</td>
                        <td class="text-primary fw-semibold">@($"R{sr.CostZAR.ToString("N2")}")</td>
                        <td class="text-muted small">@sr.ExchangeRateUsed.ToString("F4")</td>
                        <td>
                            @{
                                var sc = sr.Status switch
                                {
                                    ServiceRequestStatus.Pending => "bg-warning text-dark",
                                    ServiceRequestStatus.InProgress => "bg-primary",
                                    ServiceRequestStatus.Completed => "bg-success",
                                    ServiceRequestStatus.Cancelled => "bg-danger",
                                    _ => "bg-secondary"
                                };
                            }
                            <span class="badge @sc">@sr.Status</span>
                        </td>
                        <td class="small">@sr.RequestedOn.ToString("yyyy-MM-dd")</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@sr.Id" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i></a>
                            <a asp-action="Edit" asp-route-id="@sr.Id" class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil"></i></a>
                            <a asp-action="Delete" asp-route-id="@sr.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="10" class="text-center text-muted py-4">No service requests yet. <a asp-action="Create">Create one.</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="card-footer text-muted small">@Model.Count() request(s) total</div>
</div>
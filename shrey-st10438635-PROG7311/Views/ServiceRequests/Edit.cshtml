@model shrey_st10438635_PROG7311.Models.ServiceRequest
@{
    ViewData["Title"] = "Edit Service Request";
    var supportedCurrencies = new[] { "USD", "EUR", "GBP", "AUD", "CAD", "JPY" };
}
<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-warning text-dark">
                <i class="bi bi-pencil"></i> Edit Service Request #@Model.Id
            </div>
            <div class="card-body">
                <form asp-action="Edit">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="RequestedOn" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <div class="mb-3">
                        <label asp-for="ContractId" class="form-label fw-semibold">Contract</label>
                        <select asp-for="ContractId" asp-items="ViewBag.Contracts" class="form-select"></select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold"></label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-3">
                            <label asp-for="SourceCurrency" class="form-label fw-semibold">Currency</label>
                            <select asp-for="SourceCurrency" class="form-select">
                                @foreach (var cur in supportedCurrencies)
                                {
                                    <option value="@cur" selected="@(Model.SourceCurrency == cur ? "selected" : null)">@cur</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Cost" class="form-label fw-semibold">Cost</label>
                            <input asp-for="Cost" class="form-control" type="number" step="0.01" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="CostZAR" class="form-label fw-semibold">Cost (ZAR)</label>
                            <input asp-for="CostZAR" class="form-control" type="number" step="0.01" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="ExchangeRateUsed" class="form-label fw-semibold">Rate Used</label>
                            <input asp-for="ExchangeRateUsed" class="form-control" type="number" step="0.0001" />
                        </div>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Status" class="form-label fw-semibold"></label>
                        <select asp-for="Status" asp-items="Html.GetEnumSelectList<ServiceRequestStatus>()" class="form-select"></select>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning"><i class="bi bi-save"></i> Update</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
@model shrey_st10438635_PROG7311.Models.ServiceRequest

@*
    Shrey Singh
    ST10438635
    References:
    <Perumal, N., 2026. PROG7311 POE Part Two Workshop. [lecture] The Independent Institute of Education, 15 April 2026.>
    <Microsoft, 2026. Razor syntax reference for ASP.NET Core. [online] Microsoft Learn. Available at: https://learn.microsoft.com/en-us/aspnet/core/mvc/views/razor [Accessed 15 April 2026].>
    <W3Schools, 2026. Bootstrap 5 Tutorial. [online] W3Schools. Available at: https://www.w3schools.com/bootstrap5 [Accessed 16 April 2026].>
    <Tutorials Teacher, 2026. Tag Helpers in ASP.NET Core. [online] Available at: https://www.tutorialsteacher.com/core/aspnet-core-tag-helpers [Accessed 17 April 2026].>
    <MDN Web Docs, 2026. JavaScript Fetch API. [online] Mozilla Developer Network. Available at: https://developer.mozilla.org/en-US/docs/Web/API/Fetch_API [Accessed 18 April 2026].>
*@
@{
    ViewData["Title"] = "Delete Service Request";
    string SymbolFor(string code) => code?.ToUpperInvariant() switch
    {
        "USD" => "$",
        "EUR" => "€",
        "GBP" => "£",
        "AUD" => "A$",
        "CAD" => "C$",
        "JPY" => "¥",
        _ => code ?? ""
    };
    var symbol = SymbolFor(Model.SourceCurrency);
}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-danger shadow-sm">
            <div class="card-header bg-danger text-white">
                <i class="bi bi-exclamation-triangle"></i> Delete Service Request #@Model.Id
            </div>
            <div class="card-body">
                <p>Delete this service request from contract <strong>@Model.Contract?.Title</strong>?</p>
                <p class="text-muted">Cost: @($"{symbol}{Model.Cost.ToString("N2")}") @Model.SourceCurrency / @($"R{Model.CostZAR.ToString("N2")}")</p>
            </div>
            <div class="card-footer d-flex gap-2">
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Delete</button>
                </form>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </div>
    </div>
</div>